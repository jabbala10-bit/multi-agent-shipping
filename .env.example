# Core agent settings
POLICYMESH_MODEL=gemini-2.5-flash
POLICYMESH_ADK_HOST=127.0.0.1
POLICYMESH_ADK_PORT=8000

# Toolbox endpoints
TOOLBOX_URL=http://127.0.0.1:5000
SHOPPING_TOOLBOX_URL=http://127.0.0.1:5001
SHIPPING_TOOLBOX_URL=http://127.0.0.1:5000

# Toolbox tool names
SHOPPING_SEARCH_PRODUCTS_TOOL=search-products
SHOPPING_SEARCH_PRODUCTS_BROAD_TOOL=search-products
SHIPPING_GET_ORDER_TOOL=get-order
SHIPPING_GET_OPEN_ORDER_TOOL=get-open-order-for-user
SHIPPING_UPDATE_ORDER_ADDRESS_TOOL=update-order-address
SHIPPING_UPDATE_ORDER_STATUS_TOOL=update-order-status
SHIPPING_UPDATE_ORDER_COSTS_TOOL=update-order-costs

# Storefront remote A2A targets
POLICYMESH_SHOPPING_A2A_URL=http://127.0.0.1:8000/a2a/shopping
POLICYMESH_SHIPPING_A2A_URL=http://127.0.0.1:8000/a2a/shipping

# Product manual retrieval
DATASTORE_PROJECT_ID=
DATASTORE_ENGINE_ID=
DATASTORE_LOCATION=global

# Test/development escape hatch.
# Set to 1 when you want imports to succeed without live Toolbox services.
POLICYMESH_OFFLINE_TOOLS=0
